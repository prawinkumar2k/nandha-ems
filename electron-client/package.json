{
  "name": "nec-ems-secure-exam-client",
  "version": "1.0.0",
  "description": "Enterprise Secure Laboratory Examination Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "node-machine-id": "^1.1.12",
    "socket.io-client": "^4.7.2",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.NEC EMS.examclient",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

